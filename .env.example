# ════════════════════════════════════════════════
# HeroTalk 환경변수 템플릿
# 이 파일을 복사해서 .env 로 만든 뒤 값을 채우세요
# .env 파일은 절대 Git에 올리지 마세요!
# ════════════════════════════════════════════════

# ── 데이터베이스 (운영) ──
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# ── JWT 시크릿 (32자 이상 랜덤 문자열) ──
# 생성 방법: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# ── 카카오 OAuth2 ──
# 발급 경로: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# ── 구글 OAuth2 ──
# 발급 경로: https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Redis (운영) ──
REDIS_HOST=localhost
REDIS_PORT=6379
